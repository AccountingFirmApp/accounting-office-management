# Database Connection
DB_CONNECTION_STRING=Host=localhost;Database=Irgunit1;Username=postgres;Password=YOUR_PASSWORD_HERE

# JWT Configuration
JWT_SECRET_KEY=YourSuperSecretKeyThatMustBeAtLeast32CharactersLongForSecurity
JWT_ISSUER=AccountingSystem.API
JWT_AUDIENCE=AccountingSystem.Client

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Environment
ASPNETCORE_ENVIRONMENT=Development

# IMPORTANT: Copy this file to .env and fill in your actual values
# Never commit .env to version control!
